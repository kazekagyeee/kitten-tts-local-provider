# Silero TTS Local Provider Configuration

# Server
PORT=8000
HOST=0.0.0.0

# Audio
SAMPLE_RATE=24000

# Model: v5_5_ru (multi-speaker)
MODEL_VERSION=v5_5_ru

# Language
DEFAULT_LANGUAGE=ru

# Default voice (v5_5_ru speakers: aidar, baya, kseniya, xenia, eugene)
DEFAULT_VOICE=aidar

# Gender filter: "" (all), "male", or "female"
PREFERRED_GENDER=