# KittenTTS Local Provider Configuration

# Server
PORT=8000
HOST=0.0.0.0

# Model size: nano, nano-int8, micro, mini
# nano (15M params, ~25MB) - fastest, lower quality
# nano-int8 (15M params, ~25MB) - quantized version
# micro (40M params, ~41MB) - balanced
# mini (80M params, ~80MB) - best quality, slower
KITTEN_MODEL_SIZE=nano

# Audio
SAMPLE_RATE=24000

# Default voice: Jasper, Luna, Bella, Bruno, Rosie, Hugo, Kiki, Leo
DEFAULT_VOICE=Jasper

# CORS (comma-separated origins or * for all)
CORS_ORIGINS=*
