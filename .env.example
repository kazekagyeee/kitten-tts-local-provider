# Silero TTS Local Provider Configuration

# Server
PORT=8000
HOST=0.0.0.0

# Audio
SAMPLE_RATE=24000

# Model version: v5_5_ru, v5_4_ru, v5_3_ru, v5_2_ru, v5_ru
# v5_5_ru - latest, best quality, supports questions
# v5_4_ru - good quality, supports questions
# v5_3_ru - standard quality
MODEL_VERSION=v5_5_ru

# Language (currently only Russian supported)
DEFAULT_LANGUAGE=ru

# Default voice: aidar, baya, kseniya, xenia, eugene
# aidar - male, deep
# baya - female, warm
# kseniya - female, clear
# kseniya_v2 - female, soft
# eugene - male, standard
DEFAULT_VOICE=aidar

# Gender filter: "" (all), "male", or "female"
# PREFERRED_GENDER= # Optional, restricts available voices